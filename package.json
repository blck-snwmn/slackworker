{
	"name": "slackworker",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@11",
	"scripts": {
		"deploy": "wrangler publish",
		"start": "wrangler dev",
		"cf-typegen": "wrangler types",
		"lint": "oxlint --deny-warnings .",
		"lint:fix": "oxlint --deny-warnings . --fix",
		"fmt": "oxfmt --write src/ test/",
		"fmt:check": "oxfmt --check src/ test/"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.18.1",
		"@types/node": "26.1.1",
		"oxfmt": "0.58.0",
		"oxlint": "1.73.0",
		"oxlint-tsgolint": "0.24.0",
		"typescript": "6.0.3",
		"vitest": "4.1.10",
		"wrangler": "4.107.1"
	}
}
