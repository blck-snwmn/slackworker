{
	"name": "slackworker",
	"version": "0.0.0",
	"private": true,
	"packageManager": "pnpm@11",
	"scripts": {
		"deploy": "wrangler publish",
		"start": "wrangler dev",
		"lint": "oxlint --deny-warnings .",
		"lint:fix": "oxlint --deny-warnings . --fix",
		"fmt": "oxfmt --write src/ test/",
		"fmt:check": "oxfmt --check src/ test/"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.16.15",
		"@cloudflare/workers-types": "4.20260615.1",
		"oxfmt": "0.54.0",
		"oxlint": "1.69.0",
		"oxlint-tsgolint": "0.23.0",
		"typescript": "6.0.3",
		"vitest": "4.1.9",
		"wrangler": "4.100.0"
	}
}
